{
  "name": "habitantes-whatsapp-bot",
  "version": "1.0.0",
  "description": "WhatsApp (Baileys) DM-only channel for the Habitantes de Grenoble agent. Thin adapter: WhatsApp events <-> HTTP calls to the existing FastAPI. No agent logic.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.9",
    "js-yaml": "^4.1.0",
    "pino": "^9.5.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.17.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
