# Environment selector
APP_ENV=dev

# Secrets (DO NOT COMMIT .env)
OPENAI_API_KEY=
DATABASE_URL=
QDRANT_URL=
QDRANT_API_KEY=

# Optional: private repo access for pip installs
# Option A: personal access token (HTTPS)
GIT_TOKEN=
# Option B: SSH agent forwarding (preferred for Docker BuildKit)
# (no env var needed if using SSH agent)
