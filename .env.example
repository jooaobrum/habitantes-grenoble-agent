# ── Secrets ──────────────────────────────────────────────────────────────────
# Required: OpenAI API Key for gpt-4o-mini
OPENAI_API_KEY=sk-...

# Required: Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Required: shared secret for the Control Center's /admin/* routes (dashboard
# and the Telegram bot's heartbeat both send this as X-Admin-Token).
ADMIN_TOKEN=change-me

# Optional: Control Center alert email config. Leave unset to disable email
# sending (alerts still log and disable the switch — fail-safe by design).
# Gmail note: SMTP_FROM must match SMTP_USER (or a verified "Send mail as"
# alias) or Gmail delivers to Archive instead of the Inbox. Avoid EMAIL_TO ==
# SMTP_USER — self-addressed SMTP mail is also skipped to Archive by Gmail.
EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_FROM=
SMTP_PASSWORD=
