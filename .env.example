# ── Secrets ──────────────────────────────────────────────────────────────────
# Required: OpenRouter API Key — powers all chat/completions (agent, ingestion
# synthesis, eval judge). Default model is "google/gemini-2.5-flash-lite"; swap
# via config (llm.model_name / MODEL_NAME), e.g. "openai/gpt-4o-mini",
# "anthropic/claude-3.5-haiku".
OPENROUTER_API_KEY=sk-or-...

# Required: OpenAI API Key — embeddings only (text-embedding-3-small). OpenRouter
# has no embeddings endpoint, so retrieval still runs on OpenAI.
OPENAI_API_KEY=sk-...

# Required: Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Required for the WhatsApp channel: salt used to hash sender JIDs into chat_id.
# The raw phone number is never sent to the API — chat_id = sha256(salt + number).
# Use a long random string (e.g. `openssl rand -hex 32`). Env-only, never in yaml.
WHATSAPP_ID_SALT=change-me-to-a-long-random-string

# Required: shared secret for the Control Center's /admin/* routes (dashboard
# and the Telegram bot's heartbeat both send this as X-Admin-Token).
ADMIN_TOKEN=change-me

# Optional: Control Center alert email config. Leave unset to disable email
# sending (alerts still log and disable the switch — fail-safe by design).
# Gmail note: SMTP_FROM must match SMTP_USER (or a verified "Send mail as"
# alias) or Gmail delivers to Archive instead of the Inbox. Avoid EMAIL_TO ==
# SMTP_USER — self-addressed SMTP mail is also skipped to Archive by Gmail.
EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_FROM=
SMTP_PASSWORD=
